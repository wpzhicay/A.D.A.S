# Local Development - Use individual DB variables OR DATABASE_URL, not both
# If DATABASE_URL is set, it takes precedence over individual variables

# Option 1: Individual Database Variables (for local development)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=solar_generator

# Option 2: Full Database URL (for production/Render)
# DATABASE_URL=postgresql://user:password@host:port/database

# JWT Configuration
JWT_SECRET=your_secret_key_here_change_in_production
JWT_EXPIRATION=7d

# Node Environment
NODE_ENV=development

# Application
APP_PORT=3000
