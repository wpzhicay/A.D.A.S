{
  "buildCommand": "cd frontend && npm install --legacy-peer-deps && npm run build",
  "outputDirectory": "frontend/dist/frontend",
  "env": {
    "API_URL": {
      "description": "Backend API URL",
      "default": "http://localhost:3000/api"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
